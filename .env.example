# Nous configuration — copy to .env and adjust as needed
# All variables are optional; defaults shown below.

# Worker HTTP port
NOUS_PORT=37888

# SQLite database directory
NOUS_DATA_DIR=~/.nous

# Claude model used for session digest and knowledge extraction
# Options: haiku (fastest, cheapest), sonnet, opus
NOUS_MODEL=haiku

# Directory for auto-generated knowledge markdown files
NOUS_MEMORY_DIR=~/user_memory

# Anthropic API key — omit to reuse Claude Code's login session
# ANTHROPIC_API_KEY=sk-ant-...
